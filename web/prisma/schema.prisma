// Marketing AI — Prisma schema
//
// SQLite-backed for local dev. Stores connected Business records and
// the analyses that have been run against them. The full structured
// AnalysisResult is serialised as JSON into `payload`; a few fields are
// denormalised onto the Analysis row itself for fast list rendering
// (timestamps, token counts, summary preview, recommendation count).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Single-user account (Auth.js credentials provider). Phase 1.E ships
/// a lockdown gate: only the FIRST register call succeeds; subsequent
/// registrations get a 403. Multi-user support would change the
/// Business ↔ User relationship; for now there's exactly one User and
/// they own everything.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A business that exposes the /v1/external/* contract. Phase 1.C
/// auto-bootstraps a single row from RESTORA_API_BASE / RESTORA_API_KEY
/// env vars; Phase 1.D will replace that with an onboarding form so
/// multiple businesses can be connected.
model Business {
  id        String   @id @default(cuid())
  /// Cached display name from the most recent /business/profile call.
  name      String
  /// Base URL including the /v1/external segment, no trailing slash.
  baseUrl   String   @unique
  /// Plaintext API key for now. Encryption-at-rest is a separate phase
  /// (needs envelope-encryption with a master key).
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyses Analysis[]
}

/// One row per successful analysis run. The full AnalysisResult JSON
/// lives in `payload` so we never need migrations when the result
/// shape changes. Top-level columns are for indexed listing.
model Analysis {
  id                  String   @id @default(cuid())
  businessId          String
  /// Time the model finished writing the audit (from AnalysisResult.generatedAt).
  generatedAt         DateTime
  model               String
  /// First ~500 chars of the exec summary, for list rendering without
  /// parsing the full payload.
  summary             String
  recommendationCount Int
  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int
  cacheWriteTokens    Int
  /// JSON-serialised AnalysisResult. Read with JSON.parse() at the edge.
  payload             String
  createdAt           DateTime @default(now())

  business Business        @relation(fields: [businessId], references: [id])
  drafts   CampaignDraft[]

  @@index([businessId, createdAt])
}

/// A concrete campaign drafted from one recommendation in an Analysis.
/// Re-drafting the same rec creates a new row — we don't overwrite, so
/// the user can compare iterations. The latest row per rec is what the
/// UI shows by default.
///
/// `recIndex` points into the source Analysis.recommendations array
/// (we don't denormalise recs into their own table yet — when we do,
/// this becomes an FK).
model CampaignDraft {
  id               String   @id @default(cuid())
  analysisId       String
  recIndex         Int
  /// Cached rec title for fast list rendering without parsing the
  /// source analysis payload.
  recTitle         String
  /// PENDING_REVIEW (just drafted), APPROVED, REJECTED, DISCARDED.
  /// Approval workflow comes in a later phase — everything ships as
  /// PENDING_REVIEW until then.
  status           String   @default("PENDING_REVIEW")
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int
  cacheWriteTokens Int
  /// JSON-serialised CampaignDraftPayload (see lib/ai/draft.ts).
  payload          String
  /// When this draft is a refinement of a previous one, the user's
  /// free-text feedback that prompted it. Null on initial drafts.
  feedback         String?
  /// FK to the draft this one was refined from. Forms a chain of
  /// versions for the same recommendation. Null on the first draft.
  parentDraftId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  analysis     Analysis        @relation(fields: [analysisId], references: [id])
  parentDraft  CampaignDraft?  @relation("DraftRefinement", fields: [parentDraftId], references: [id])
  refinedDrafts CampaignDraft[] @relation("DraftRefinement")
  smsSendEvents SmsSendEvent[]
  smsBlastEvents SmsBlastEvent[]
  scheduledSends ScheduledSend[]
  recurringSchedules RecurringSchedule[]
  pieceCompletions   PieceCompletion[]

  @@index([analysisId, recIndex])
  @@index([parentDraftId])
}

/// User-marked "I did this myself" toggle on a draft piece. Covers
/// every piece type — SMS sent through a different provider, visual
/// briefs handed to a designer, menu changes made directly in Restora,
/// in-store cards printed, etc. The integrated SMS-send path also
/// auto-marks completion when a piece sends successfully through
/// Restora, so the dashboard's completion view is uniform regardless
/// of how the work actually happened.
///
/// One row per (draftId, pieceIndex). Unchecking deletes the row.
model PieceCompletion {
  id          String   @id @default(cuid())
  draftId     String
  pieceIndex  Int
  /// Free-text notes the user attached to the completion ("sent via
  /// Twilio campaign id ABC123", "menu updated 14 May 2pm", etc.).
  notes       String?
  /// Distinguishes self-marked vs auto-marked completions.
  source      String   @default("manual")
  completedAt DateTime @default(now())

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@unique([draftId, pieceIndex])
  @@index([completedAt])
}

/// One row per attempted SMS send (test or production). Persisted
/// BEFORE the upstream call so even network failures get audited; the
/// status is updated to SENT/FAILED after the Restora API call returns.
///
/// `pieceIndex` points into the draft's payload.pieces array at the
/// time of send. If the draft is later re-drafted (which produces a
/// new row, leaving this one alone), the index still resolves
/// correctly against the original draft.
model SmsSendEvent {
  id                String   @id @default(cuid())
  draftId           String
  pieceIndex        Int
  toPhone           String
  body              String
  campaignTag       String?
  /// PENDING (in flight), SENT (success), FAILED (caught error),
  /// PROVIDER_ERROR (Restora returned ok=false).
  status            String   @default("PENDING")
  /// `requestId` returned by Restora — useful for cross-referencing
  /// against Restora's sms_logs row.
  providerRequestId String?
  providerStatus    String?
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@index([draftId, createdAt])
}

/// A send that's been queued to fire at a future time. The instrumentation
/// hook polls every ~30s, picks up rows where scheduledAt <= now and
/// status = PENDING, and executes them via the same libs used by the
/// on-demand send routes.
///
/// `kind`:
///   - 'single' — send to one phone (config = { phone })
///   - 'blast'  — send to a segment   (config = { segment, campaignTag? })
///
/// `config` is a JSON blob so the schema doesn't fork per kind.
///
/// A scheduled send only fires while its source draft is APPROVED. If the
/// draft gets re-opened (back to PENDING_REVIEW) or rejected, the
/// scheduler skips it and marks SKIPPED with a reason.
model ScheduledSend {
  id            String   @id @default(cuid())
  draftId       String
  pieceIndex    Int
  kind          String   // 'single' | 'blast'
  /// JSON: { phone } for single, { segment, campaignTag? } for blast.
  config        String
  scheduledAt   DateTime
  /// PENDING (waiting to fire), RUNNING (worker is currently sending),
  /// COMPLETED (fired successfully), FAILED (worker hit an error and
  /// gave up), SKIPPED (draft no longer APPROVED at fire time),
  /// CANCELED (user canceled before fire).
  status        String   @default("PENDING")
  attemptCount  Int      @default(0)
  lastAttemptAt DateTime?
  lastError     String?
  completedAt   DateTime?
  /// JSON snapshot of the executed send/blast result (SmsSendEvent or
  /// SmsBlastEvent payload depending on kind), so the dashboard can
  /// render the outcome without an extra join.
  resultJson    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@index([status, scheduledAt])
  @@index([draftId, pieceIndex])
}

/// A long-lived recurring SMS schedule — the "weekly Thursday 10am to
/// inactive customers" pattern. Each fire executes via the same
/// execute-sends libs as one-off ScheduledSend rows; the difference is
/// that after firing, the scheduler bumps `nextFireAt` forward by one
/// week instead of marking the row COMPLETED.
///
/// Frequency is `weekly` only for now — monthly is rare in marketing
/// and the schema can grow later without a migration if we add it.
///
/// Timezone is captured for future DST correctness. In Asia/Dhaka (no
/// DST) the simple +7-day bump preserves the local time-of-day, so we
/// don't need timezone math at fire time today.
model RecurringSchedule {
  id          String   @id @default(cuid())
  draftId     String
  pieceIndex  Int
  kind        String // 'single' | 'blast'
  config      String // same JSON shape as ScheduledSend.config
  frequency   String // 'weekly' for now
  dayOfWeek   Int // 0-6, 0=Sunday — convention matches JS Date.getDay()
  hour        Int // 0-23 in the schedule's timezone
  minute      Int // 0-59 in the schedule's timezone
  timezone    String // IANA name, e.g. 'Asia/Dhaka'
  active      Boolean   @default(true)
  /// Pre-computed UTC moment of the next fire. Bumped by the scheduler
  /// after each successful fire; the scheduler only ever picks rows
  /// where active=true and nextFireAt<=now.
  nextFireAt  DateTime
  lastFireAt  DateTime?
  runCount    Int       @default(0)
  startsAt    DateTime
  endsAt      DateTime?
  /// Last error from a failed fire; informational only — the schedule
  /// keeps running on its cadence.
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@index([active, nextFireAt])
  @@index([draftId, pieceIndex])
}

/// One row per segment blast attempt. Holds the segment filter snapshot,
/// rendered template body, and aggregate sent/failed counts. The
/// granular per-recipient sms_logs live on Restora's side — this is a
/// summary record so the dashboard can show "Sent to 47 / 53 · 2h ago"
/// without round-tripping.
model SmsBlastEvent {
  id              String   @id @default(cuid())
  draftId         String
  pieceIndex      Int
  /// JSON snapshot of the segment filter (minSpent, minVisits, etc.).
  segmentFilter   String
  /// Human-readable segment description rendered at submit time, e.g.
  /// "Visited in last 30 days · min spend ৳500".
  segmentLabel    String
  body            String
  campaignTag     String?
  /// PENDING (in flight), COMPLETE (no failures), PARTIAL (some failed),
  /// FAILED (catastrophic, e.g. upstream 5xx).
  status          String   @default("PENDING")
  recipientCount  Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@index([draftId, createdAt])
}
