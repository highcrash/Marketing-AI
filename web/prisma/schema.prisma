// Marketing AI — Prisma schema
//
// SQLite-backed for local dev. Stores connected Business records and
// the analyses that have been run against them. The full structured
// AnalysisResult is serialised as JSON into `payload`; a few fields are
// denormalised onto the Analysis row itself for fast list rendering
// (timestamps, token counts, summary preview, recommendation count).

generator client {
  provider      = "prisma-client-js"
  // Targets we need at runtime: 'native' covers the local Windows dev
  // box; 'debian-openssl-3.0.x' covers the Ubuntu 24.04 droplet.
  // Without the explicit Linux target, `next build` on Windows only
  // ships the Windows query engine and the server crashes on boot.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// User account (Auth.js credentials provider).
///
/// Phase 1.E shipped single-user lockdown; multi-tenant V2 lifts that
/// gate by introducing Organization + OrgMembership. The first user
/// to register still gets the original /register flow; additional
/// users are added through org-level invitations (route TBD when UI
/// guidelines land).
///
/// `activeBusinessId` is per-user UI state: when a user belongs to
/// multiple orgs (and therefore multiple businesses), this is the one
/// the dashboard renders by default. Null means "use whichever business
/// the env points at" — the pre-multi-tenant default.
model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String?
  activeBusinessId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships OrgMembership[]
}

/// Top-level tenant boundary. Everything billable + everything that
/// could conceivably belong to a different paying customer lives
/// under an Organization. A solo owner-operator has exactly one org
/// and one Business under it; an agency managing many restaurants
/// has one org per agency (with multiple businesses) OR one org per
/// restaurant — depends on how they want to scope users + billing.
model Organization {
  id        String   @id @default(cuid())
  name      String
  /// Slug for nice URLs once the dashboard surfaces an org switcher.
  /// Auto-derived from name on create + uniqueness-suffixed when
  /// collisions happen. Lowercase, kebab-case.
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships OrgMembership[]
  businesses  Business[]
}

/// Many-to-many between users and orgs with a role attached. OWNER is
/// the org creator and can never be removed (must transfer first);
/// ADMIN can manage members + businesses; MEMBER can only see/use
/// businesses, not change org-level settings.
model OrgMembership {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      String   @default("MEMBER") // OWNER | ADMIN | MEMBER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

/// A business that exposes the /v1/external/* contract. Phase 1.C
/// auto-bootstraps a single row from RESTORA_API_BASE / RESTORA_API_KEY
/// env vars; Phase 1.D will replace that with an onboarding form so
/// multiple businesses can be connected.
model Business {
  id        String   @id @default(cuid())
  /// Owning organization. Nullable for backwards compat with the
  /// pre-multi-tenant single-business deployments; new businesses
  /// MUST be created under an org via the onboarding flow.
  organizationId String?
  /// Cached display name from the most recent /business/profile call.
  name      String
  /// Base URL including the /v1/external segment, no trailing slash.
  baseUrl   String   @unique
  /// Plaintext API key for now. Encryption-at-rest is a separate phase
  /// (needs envelope-encryption with a master key).
  apiKey    String
  /// JSON array of pre-selected goals (e.g. ["acquisition","retention"])
  /// that the audit pipeline injects into the system prompt so Claude
  /// tilts recommendations toward what the owner explicitly wants. Empty
  /// array (default) means "let the model infer goals from the data".
  goalTags  String   @default("[]")
  /// Free-text business context the owner wants the audit to consider
  /// (e.g. "we're opening a second branch in Q3", "Eid week is our
  /// biggest revenue spike"). Null when never set.
  goalNotes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  analyses Analysis[]
  facebookConnections FacebookConnection[]
  facebookPostEvents  FacebookPostEvent[]

  @@index([organizationId])
}

/// One Facebook Page that this business has authorised the platform to
/// post to. The `accessToken` is a Page Access Token (Graph API);
/// `tokenExpiresAt` is null for long-lived tokens that don't expire and
/// otherwise the Graph-reported expiration. The connection is treated as
/// dead once the validator hits an OAuthException — `lastValidatedAt`
/// and `lastValidationError` capture that.
///
/// One business can have many pages; the UI picks one when the user
/// clicks "Post to Facebook" on a draft piece with channel=facebook.
model FacebookConnection {
  id                  String   @id @default(cuid())
  businessId          String
  pageId              String
  pageName            String
  accessToken         String
  /// 'long-lived' (Graph: never expires for Page tokens with appropriate
  /// scopes) or an ISO datetime. We keep it as a nullable DateTime —
  /// null means "long-lived / no expiry reported".
  tokenExpiresAt      DateTime?
  active              Boolean   @default(true)
  lastValidatedAt     DateTime?
  lastValidationError String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  business    Business             @relation(fields: [businessId], references: [id])
  postEvents  FacebookPostEvent[]

  @@unique([businessId, pageId])
  @@index([businessId, active])
}

/// One row per attempted post-to-Facebook. Persisted BEFORE the upstream
/// call so even network failures get audited; the status flips to
/// POSTED or FAILED after the Graph API call returns. The
/// `providerPostId` is the Graph-returned post id (page_id_post_id
/// format) so the user can click through to the live post.
model FacebookPostEvent {
  id              String   @id @default(cuid())
  businessId      String
  connectionId    String
  draftId         String?
  pieceIndex      Int?
  message         String
  /// PENDING (in flight), POSTED (success), FAILED (caught error),
  /// PROVIDER_ERROR (Graph returned an error envelope).
  status          String   @default("PENDING")
  providerPostId  String?
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business    Business           @relation(fields: [businessId], references: [id])
  connection  FacebookConnection @relation(fields: [connectionId], references: [id])

  @@index([businessId, createdAt])
  @@index([connectionId, createdAt])
}

/// A short tracking code attached to a campaign piece — typed at POS
/// or counted manually by the owner to attribute revenue back to the
/// campaign. Self-contained on the Marketing AI side so no Restora
/// changes are needed; when Restora later exposes redemption events
/// via /external we plug those into the redemption ledger
/// automatically.
///
/// Codes are short + memorable (e.g. EATRO-M5-001) so customers can
/// say them at the counter.
model CampaignCode {
  id          String   @id @default(cuid())
  /// Globally unique short code. Case-insensitive on lookup but
  /// stored uppercase.
  code        String   @unique
  /// The draft + piece this code was minted for. recIndex is denormalised
  /// onto the draft, not duplicated here.
  draftId     String
  pieceIndex  Int
  /// Free-text label the dashboard shows (e.g. "Inactive customer SMS").
  /// Falls back to the piece title when null.
  label       String?
  /// Optional expiry; null = never expires. Soft-check only — server
  /// doesn't auto-reject redemptions past expiry, it just flags them.
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  draft       CampaignDraft         @relation(fields: [draftId], references: [id])
  redemptions CampaignRedemption[]

  @@index([draftId, pieceIndex])
}

/// One redemption event against a CampaignCode. Could be entered
/// manually by the owner ("3 customers used the code today, ৳1,400")
/// or pushed by a future Restora /external webhook.
model CampaignRedemption {
  id          String   @id @default(cuid())
  codeId      String
  /// Revenue attributed to this redemption in minor units (paisa).
  amountMinor Int      @default(0)
  /// Number of distinct customers / orders that used the code in this
  /// redemption batch.
  qty         Int      @default(1)
  /// Where the redemption signal came from: 'manual' (owner typed it
  /// in), 'restora-webhook' (future), 'pos-export' (future bulk import).
  source      String   @default("manual")
  notes       String?
  redeemedAt  DateTime @default(now())

  code CampaignCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@index([codeId, redeemedAt])
}

/// A time-bucketed campaign plan derived from one Analysis. Holds the
/// owner-set budget + horizon + disabled-category choices, plus the
/// AI-generated calendar of tasks as a JSON payload. Multiple plans
/// can exist per analysis (different budgets, what-if scenarios) —
/// the dashboard surfaces the most recent by default.
model CampaignPlan {
  id                  String   @id @default(cuid())
  analysisId          String
  /// Total budget in minor units (paisa for BDT).
  totalBudgetMinor    Int
  /// Calendar horizon in days; typically 30 / 60 / 90.
  horizonDays         Int
  /// Local start date 'YYYY-MM-DD' (business timezone).
  startDate           String
  /// JSON-encoded string[] of DisabledCategory values.
  disabledCategories  String   @default("[]")
  model               String
  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int
  cacheWriteTokens    Int
  /// JSON-encoded CampaignPlan body (summary, redistributionNotes,
  /// weeks, tasks) — read with JSON.parse at the edge so the shape
  /// can evolve without migrations.
  payload             String
  createdAt           DateTime @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id])

  @@index([analysisId, createdAt])
}

/// One row per successful analysis run. The full AnalysisResult JSON
/// lives in `payload` so we never need migrations when the result
/// shape changes. Top-level columns are for indexed listing.
model Analysis {
  id                  String   @id @default(cuid())
  businessId          String
  /// Time the model finished writing the audit (from AnalysisResult.generatedAt).
  generatedAt         DateTime
  model               String
  /// First ~500 chars of the exec summary, for list rendering without
  /// parsing the full payload.
  summary             String
  recommendationCount Int
  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int
  cacheWriteTokens    Int
  /// JSON-serialised AnalysisResult. Read with JSON.parse() at the edge.
  payload             String
  createdAt           DateTime @default(now())

  business Business        @relation(fields: [businessId], references: [id])
  drafts   CampaignDraft[]
  plans    CampaignPlan[]

  @@index([businessId, createdAt])
}

/// A concrete campaign drafted from one recommendation in an Analysis.
/// Re-drafting the same rec creates a new row — we don't overwrite, so
/// the user can compare iterations. The latest row per rec is what the
/// UI shows by default.
///
/// `recIndex` points into the source Analysis.recommendations array
/// (we don't denormalise recs into their own table yet — when we do,
/// this becomes an FK).
model CampaignDraft {
  id               String   @id @default(cuid())
  analysisId       String
  recIndex         Int
  /// Cached rec title for fast list rendering without parsing the
  /// source analysis payload.
  recTitle         String
  /// PENDING_REVIEW (just drafted), APPROVED, REJECTED, DISCARDED.
  /// Approval workflow comes in a later phase — everything ships as
  /// PENDING_REVIEW until then.
  status           String   @default("PENDING_REVIEW")
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int
  cacheWriteTokens Int
  /// JSON-serialised CampaignDraftPayload (see lib/ai/draft.ts).
  payload          String
  /// When this draft is a refinement of a previous one, the user's
  /// free-text feedback that prompted it. Null on initial drafts.
  feedback         String?
  /// FK to the draft this one was refined from. Forms a chain of
  /// versions for the same recommendation. Null on the first draft.
  parentDraftId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  analysis     Analysis        @relation(fields: [analysisId], references: [id])
  parentDraft  CampaignDraft?  @relation("DraftRefinement", fields: [parentDraftId], references: [id])
  refinedDrafts CampaignDraft[] @relation("DraftRefinement")
  smsSendEvents SmsSendEvent[]
  smsBlastEvents SmsBlastEvent[]
  scheduledSends ScheduledSend[]
  recurringSchedules RecurringSchedule[]
  pieceCompletions   PieceCompletion[]
  campaignCodes      CampaignCode[]

  @@index([analysisId, recIndex])
  @@index([parentDraftId])
}

/// User-marked "I did this myself" toggle on a draft piece. Covers
/// every piece type — SMS sent through a different provider, visual
/// briefs handed to a designer, menu changes made directly in Restora,
/// in-store cards printed, etc. The integrated SMS-send path also
/// auto-marks completion when a piece sends successfully through
/// Restora, so the dashboard's completion view is uniform regardless
/// of how the work actually happened.
///
/// One row per (draftId, pieceIndex). Unchecking deletes the row.
model PieceCompletion {
  id          String   @id @default(cuid())
  draftId     String
  pieceIndex  Int
  /// Free-text notes the user attached to the completion ("sent via
  /// Twilio campaign id ABC123", "menu updated 14 May 2pm", etc.).
  notes       String?
  /// Distinguishes self-marked vs auto-marked completions.
  source      String   @default("manual")
  /// Optional proof-of-work attachment: screenshot of the sent SMS,
  /// receipt for the printed in-store cards, photo of the finished
  /// physical campaign, etc. All four fields are populated together
  /// when an attachment is present and null when none.
  attachmentPath String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?
  completedAt DateTime @default(now())

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@unique([draftId, pieceIndex])
  @@index([completedAt])
}

/// One row per attempted SMS send (test or production). Persisted
/// BEFORE the upstream call so even network failures get audited; the
/// status is updated to SENT/FAILED after the Restora API call returns.
///
/// `pieceIndex` points into the draft's payload.pieces array at the
/// time of send. If the draft is later re-drafted (which produces a
/// new row, leaving this one alone), the index still resolves
/// correctly against the original draft.
model SmsSendEvent {
  id                String   @id @default(cuid())
  draftId           String
  pieceIndex        Int
  toPhone           String
  body              String
  campaignTag       String?
  /// PENDING (in flight), SENT (success), FAILED (caught error),
  /// PROVIDER_ERROR (Restora returned ok=false).
  status            String   @default("PENDING")
  /// `requestId` returned by Restora — useful for cross-referencing
  /// against Restora's sms_logs row.
  providerRequestId String?
  providerStatus    String?
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@index([draftId, createdAt])
}

/// A send that's been queued to fire at a future time. The instrumentation
/// hook polls every ~30s, picks up rows where scheduledAt <= now and
/// status = PENDING, and executes them via the same libs used by the
/// on-demand send routes.
///
/// `kind`:
///   - 'single' — send to one phone (config = { phone })
///   - 'blast'  — send to a segment   (config = { segment, campaignTag? })
///
/// `config` is a JSON blob so the schema doesn't fork per kind.
///
/// A scheduled send only fires while its source draft is APPROVED. If the
/// draft gets re-opened (back to PENDING_REVIEW) or rejected, the
/// scheduler skips it and marks SKIPPED with a reason.
model ScheduledSend {
  id            String   @id @default(cuid())
  draftId       String
  pieceIndex    Int
  kind          String   // 'single' | 'blast'
  /// JSON: { phone } for single, { segment, campaignTag? } for blast.
  config        String
  scheduledAt   DateTime
  /// PENDING (waiting to fire), RUNNING (worker is currently sending),
  /// COMPLETED (fired successfully), FAILED (worker hit an error and
  /// gave up), SKIPPED (draft no longer APPROVED at fire time),
  /// CANCELED (user canceled before fire).
  status        String   @default("PENDING")
  attemptCount  Int      @default(0)
  lastAttemptAt DateTime?
  lastError     String?
  completedAt   DateTime?
  /// JSON snapshot of the executed send/blast result (SmsSendEvent or
  /// SmsBlastEvent payload depending on kind), so the dashboard can
  /// render the outcome without an extra join.
  resultJson    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@index([status, scheduledAt])
  @@index([draftId, pieceIndex])
}

/// A long-lived recurring SMS schedule — the "weekly Thursday 10am to
/// inactive customers" pattern. Each fire executes via the same
/// execute-sends libs as one-off ScheduledSend rows; the difference is
/// that after firing, the scheduler bumps `nextFireAt` forward by one
/// week instead of marking the row COMPLETED.
///
/// Frequency is `weekly` only for now — monthly is rare in marketing
/// and the schema can grow later without a migration if we add it.
///
/// Timezone is captured for future DST correctness. In Asia/Dhaka (no
/// DST) the simple +7-day bump preserves the local time-of-day, so we
/// don't need timezone math at fire time today.
model RecurringSchedule {
  id          String   @id @default(cuid())
  draftId     String
  pieceIndex  Int
  kind        String // 'single' | 'blast'
  config      String // same JSON shape as ScheduledSend.config
  frequency   String // 'weekly' for now
  dayOfWeek   Int // 0-6, 0=Sunday — convention matches JS Date.getDay()
  hour        Int // 0-23 in the schedule's timezone
  minute      Int // 0-59 in the schedule's timezone
  timezone    String // IANA name, e.g. 'Asia/Dhaka'
  active      Boolean   @default(true)
  /// Pre-computed UTC moment of the next fire. Bumped by the scheduler
  /// after each successful fire; the scheduler only ever picks rows
  /// where active=true and nextFireAt<=now.
  nextFireAt  DateTime
  lastFireAt  DateTime?
  runCount    Int       @default(0)
  startsAt    DateTime
  endsAt      DateTime?
  /// Last error from a failed fire; informational only — the schedule
  /// keeps running on its cadence.
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@index([active, nextFireAt])
  @@index([draftId, pieceIndex])
}

/// One row per segment blast attempt. Holds the segment filter snapshot,
/// rendered template body, and aggregate sent/failed counts. The
/// granular per-recipient sms_logs live on Restora's side — this is a
/// summary record so the dashboard can show "Sent to 47 / 53 · 2h ago"
/// without round-tripping.
model SmsBlastEvent {
  id              String   @id @default(cuid())
  draftId         String
  pieceIndex      Int
  /// JSON snapshot of the segment filter (minSpent, minVisits, etc.).
  segmentFilter   String
  /// Human-readable segment description rendered at submit time, e.g.
  /// "Visited in last 30 days · min spend ৳500".
  segmentLabel    String
  body            String
  campaignTag     String?
  /// PENDING (in flight), COMPLETE (no failures), PARTIAL (some failed),
  /// FAILED (catastrophic, e.g. upstream 5xx).
  status          String   @default("PENDING")
  recipientCount  Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  draft CampaignDraft @relation(fields: [draftId], references: [id])

  @@index([draftId, createdAt])
}
