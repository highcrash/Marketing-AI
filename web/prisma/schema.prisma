// Marketing AI — Prisma schema
//
// SQLite-backed for local dev. Stores connected Business records and
// the analyses that have been run against them. The full structured
// AnalysisResult is serialised as JSON into `payload`; a few fields are
// denormalised onto the Analysis row itself for fast list rendering
// (timestamps, token counts, summary preview, recommendation count).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A business that exposes the /v1/external/* contract. Phase 1.C
/// auto-bootstraps a single row from RESTORA_API_BASE / RESTORA_API_KEY
/// env vars; Phase 1.D will replace that with an onboarding form so
/// multiple businesses can be connected.
model Business {
  id        String   @id @default(cuid())
  /// Cached display name from the most recent /business/profile call.
  name      String
  /// Base URL including the /v1/external segment, no trailing slash.
  baseUrl   String   @unique
  /// Plaintext API key for now. Encryption-at-rest is a separate phase
  /// (needs envelope-encryption with a master key).
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyses Analysis[]
}

/// One row per successful analysis run. The full AnalysisResult JSON
/// lives in `payload` so we never need migrations when the result
/// shape changes. Top-level columns are for indexed listing.
model Analysis {
  id                  String   @id @default(cuid())
  businessId          String
  /// Time the model finished writing the audit (from AnalysisResult.generatedAt).
  generatedAt         DateTime
  model               String
  /// First ~500 chars of the exec summary, for list rendering without
  /// parsing the full payload.
  summary             String
  recommendationCount Int
  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int
  cacheWriteTokens    Int
  /// JSON-serialised AnalysisResult. Read with JSON.parse() at the edge.
  payload             String
  createdAt           DateTime @default(now())

  business Business        @relation(fields: [businessId], references: [id])
  drafts   CampaignDraft[]

  @@index([businessId, createdAt])
}

/// A concrete campaign drafted from one recommendation in an Analysis.
/// Re-drafting the same rec creates a new row — we don't overwrite, so
/// the user can compare iterations. The latest row per rec is what the
/// UI shows by default.
///
/// `recIndex` points into the source Analysis.recommendations array
/// (we don't denormalise recs into their own table yet — when we do,
/// this becomes an FK).
model CampaignDraft {
  id               String   @id @default(cuid())
  analysisId       String
  recIndex         Int
  /// Cached rec title for fast list rendering without parsing the
  /// source analysis payload.
  recTitle         String
  /// PENDING_REVIEW (just drafted), APPROVED, REJECTED, DISCARDED.
  /// Approval workflow comes in a later phase — everything ships as
  /// PENDING_REVIEW until then.
  status           String   @default("PENDING_REVIEW")
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int
  cacheWriteTokens Int
  /// JSON-serialised CampaignDraftPayload (see lib/ai/draft.ts).
  payload          String
  /// When this draft is a refinement of a previous one, the user's
  /// free-text feedback that prompted it. Null on initial drafts.
  feedback         String?
  /// FK to the draft this one was refined from. Forms a chain of
  /// versions for the same recommendation. Null on the first draft.
  parentDraftId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  analysis     Analysis        @relation(fields: [analysisId], references: [id])
  parentDraft  CampaignDraft?  @relation("DraftRefinement", fields: [parentDraftId], references: [id])
  refinedDrafts CampaignDraft[] @relation("DraftRefinement")

  @@index([analysisId, recIndex])
  @@index([parentDraftId])
}
